# Drizzle Kit / Studio（ローカル SQLite）。未設定時は backend/src/db/local.db
# DATABASE_URL=

# ローカルで `bun run dev` する場合の Better Auth（Wrangler 開発時は .dev.vars 等を参照）
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:8080
# FRONTEND_URL=http://localhost:3000

# ロードマップ AI 生成（任意）
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash


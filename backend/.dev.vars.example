# コピーして `.dev.vars` にリネームし、値を埋めてください（`.dev.vars` は gitignore 済み）
# ローカルでは同名キーが wrangler.toml の [vars] より優先されます

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8080

# frontend/vite.config.ts の server.port（既定 3000）と揃える
FRONTEND_URL=http://localhost:3000

STRIPE_SECRET_KEY=
# wrangler dev（localhost）+ sk_test_ なら署名検証を省略するため未設定でも可。本番・トンネル先では whsec 必須
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

GEMINI_API_KEY=

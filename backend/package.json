{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bunx wrangler d1 migrations apply rikai_db --local",
    "db:seed": "bun scripts/seed-local.ts",
    "db:reset": "bunx wrangler d1 migrations apply rikai_db --local && bun scripts/seed-local.ts",
    "db:studio": "drizzle-kit studio",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun dist/index.js",
    "lint": "oxlint -c ../.oxlintrc.json --import-plugin --node-plugin --promise-plugin --tsconfig ./tsconfig.json ./src",
    "lint:fix": "oxlint -c ../.oxlintrc.json --import-plugin --node-plugin --promise-plugin --tsconfig ./tsconfig.json --fix ./src",
    "format": "oxfmt -c ../.oxfmtrc.json --write ./src",
    "format:check": "oxfmt -c ../.oxfmtrc.json --check ./src"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.3",
    "stripe": "^22.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "better-sqlite3": "^12.5.0",
    "bun-types": "1.3.12",
    "drizzle-kit": "^0.31.8"
  }
}
